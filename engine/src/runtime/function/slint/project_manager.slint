import { Button, HorizontalBox, LineEdit, VerticalBox } from "std-widgets.slint";

export struct ProjectRow {
    name: string,
    path: string,
    missing: bool,
    last-opened: string,
}

export component ProjectManagerWindow inherits Window {
    title: "Blunder Project Manager";
    preferred-width: 1100px;
    preferred-height: 700px;
    background: #181818;

    in-out property <[ProjectRow]> projects: [];
    in-out property <int> selected-index: -1;
    in property <string> status-text: "";

    in-out property <bool> create-dialog-visible: false;
    in-out property <string> create-name: "New Project";
    in-out property <string> create-path: "";
    in-out property <bool> create-folder: true;

    in-out property <bool> import-dialog-visible: false;
    in-out property <string> import-path: "";

    callback open-requested();
    callback remove-requested();
    callback create-browse-requested();
    callback create-confirm-requested();
    callback create-cancel-requested();
    callback import-browse-requested();
    callback import-confirm-requested();
    callback import-cancel-requested();
    callback show-create-requested();
    callback show-import-requested();
    callback selection-changed(int);

    VerticalBox {
        padding: 0;
        spacing: 0;

        // Top chrome: brand + Projects tab
        Rectangle {
            height: 48px;
            background: #1f1f1f;
            HorizontalBox {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 24px;
                alignment: start;
                Text {
                    text: "BLUNDER";
                    color: #eeeeee;
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                VerticalBox {
                    alignment: center;
                    spacing: 0;
                    Text {
                        text: "Projects";
                        color: #eeeeee;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }
                    Rectangle {
                        height: 2px;
                        background: #3a6ea5;
                        width: 64px;
                    }
                }
            }
        }
        Rectangle { height: 1px; background: #2a2a2a; }

        // Body: toolbar + list + side actions
        HorizontalBox {
            padding: 12px;
            spacing: 12px;

            VerticalBox {
                spacing: 10px;
                horizontal-stretch: 1;

                HorizontalBox {
                    spacing: 8px;
                    Button {
                        text: "Create";
                        clicked => { root.show-create-requested(); }
                    }
                    Button {
                        text: "Import";
                        clicked => { root.show-import-requested(); }
                    }
                }

                Rectangle {
                    background: #1f1f1f;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #2d2d2d;
                    vertical-stretch: 1;
                    VerticalBox {
                        padding: 6px;
                        spacing: 2px;
                        if root.projects.length == 0: Text {
                            text: "No projects yet. Create or Import to get started.";
                            color: #888888;
                            padding: 12px;
                        }
                        for project[index] in root.projects: Rectangle {
                            height: 56px;
                            background: index == root.selected-index ? #2a3a4a : transparent;
                            border-radius: 3px;
                            HorizontalBox {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 16px;
                                VerticalBox {
                                    spacing: 2px;
                                    vertical-stretch: 1;
                                    alignment: center;
                                    Text {
                                        text: project.name;
                                        color: project.missing ? #cc6666 : #eeeeee;
                                        font-size: 14px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: project.missing ? project.path + " (missing)" : project.path;
                                        color: #888888;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                }
                                Text {
                                    text: project.last-opened;
                                    color: #888888;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-alignment: right;
                                    width: 150px;
                                }
                            }
                            TouchArea {
                                clicked => {
                                    root.selected-index = index;
                                    root.selection-changed(index);
                                }
                                double-clicked => {
                                    root.selected-index = index;
                                    root.selection-changed(index);
                                    root.open-requested();
                                }
                            }
                        }
                    }
                }
            }

            // Side actions
            VerticalBox {
                width: 140px;
                spacing: 8px;
                padding-top: 34px;
                Button {
                    text: "Open";
                    enabled: root.selected-index >= 0;
                    clicked => { root.open-requested(); }
                }
                Button {
                    text: "Remove";
                    enabled: root.selected-index >= 0;
                    clicked => { root.remove-requested(); }
                }
            }
        }

        Rectangle { height: 1px; background: #2a2a2a; }
        Rectangle {
            height: 28px;
            background: #1f1f1f;
            HorizontalBox {
                padding-left: 12px;
                padding-right: 12px;
                Text {
                    text: root.status-text;
                    color: #cccc66;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }

    if root.create-dialog-visible: Rectangle {
        background: #000000aa;
        VerticalBox {
            alignment: center;
            HorizontalBox {
                alignment: center;
                Rectangle {
                    width: 500px;
                    background: #2d2d2d;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #3a3a3a;
                    VerticalBox {
                        padding: 20px;
                        spacing: 12px;
                        Text {
                            text: "Create New Project";
                            color: #eeeeee;
                            font-size: 16px;
                            font-weight: 700;
                        }
                        Text { text: "Name"; color: #999999; font-size: 12px; }
                        LineEdit { text <=> root.create-name; }
                        Text { text: "Path"; color: #999999; font-size: 12px; }
                        HorizontalBox {
                            spacing: 8px;
                            LineEdit {
                                horizontal-stretch: 1;
                                text <=> root.create-path;
                            }
                            Button {
                                text: "Browse…";
                                clicked => { root.create-browse-requested(); }
                            }
                        }
                        HorizontalBox {
                            spacing: 8px;
                            Text {
                                text: "Create Folder";
                                color: #999999;
                                vertical-alignment: center;
                            }
                            Button {
                                text: root.create-folder ? "On" : "Off";
                                clicked => { root.create-folder = !root.create-folder; }
                            }
                        }
                        HorizontalBox {
                            alignment: end;
                            spacing: 8px;
                            Button {
                                text: "Cancel";
                                clicked => { root.create-cancel-requested(); }
                            }
                            Button {
                                text: "Create & Open";
                                clicked => { root.create-confirm-requested(); }
                            }
                        }
                    }
                }
            }
        }
    }

    if root.import-dialog-visible: Rectangle {
        background: #000000aa;
        VerticalBox {
            alignment: center;
            HorizontalBox {
                alignment: center;
                Rectangle {
                    width: 500px;
                    background: #2d2d2d;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #3a3a3a;
                    VerticalBox {
                        padding: 20px;
                        spacing: 12px;
                        Text {
                            text: "Import Existing Project";
                            color: #eeeeee;
                            font-size: 16px;
                            font-weight: 700;
                        }
                        Text {
                            text: "Project path (folder or project.blunder)";
                            color: #999999;
                            font-size: 12px;
                        }
                        HorizontalBox {
                            spacing: 8px;
                            LineEdit {
                                horizontal-stretch: 1;
                                text <=> root.import-path;
                            }
                            Button {
                                text: "Browse…";
                                clicked => { root.import-browse-requested(); }
                            }
                        }
                        HorizontalBox {
                            alignment: end;
                            spacing: 8px;
                            Button {
                                text: "Cancel";
                                clicked => { root.import-cancel-requested(); }
                            }
                            Button {
                                text: "Import & Open";
                                clicked => { root.import-confirm-requested(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
