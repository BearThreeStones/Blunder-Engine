import { Button, CheckBox, HorizontalBox, Slider, VerticalBox } from "std-widgets.slint";
import { ContentBrowser, BrowserTreeRow, BrowserGridRow, BrowserPathSegment } from "content_browser.slint";
import { ImportMeshDialog } from "import_mesh_dialog.slint";
import { PiercingMenu, PiercingMenuRow } from "piercing_menu.slint";
import { HierarchyPanel, HierarchyTreeRow } from "hierarchy.slint";
import { ViewportProjectionToggle } from "viewport_projection_toggle.slint";
import { TransformToolbar } from "transform_toolbar.slint";
import { InspectorPanel } from "inspector_panel.slint";
import { FloatingPanelWindow } from "floating_panel_window.slint";
export { FloatingPanelWindow }
import { DockChromeBar, DockChromeMetrics, DockSplittersLayer, DockGuidesLayer, DockHostGuidesLayer, DockAutoHideDropPreviewLayer, DockAutoHideTabsLayer, DockAutoHideOverlaysLayer, DockFloatingDragPreviewLayer, DockTile, DockTab, DockSplitterHandle, DockGuide, DockHostGuide, DockPreview, DockAutoHideDropPreview, DockDragPreview, DockFloating, DockAutoHideTab, DockAutoHideOverlay } from "docking_panel.slint";

export component MainEditorWindow inherits Window {
    // Logical size comes only from C++ dispatch_resize_event (see SlintWindowAdapter).
    title: "Blunder Editor";
    background: #181818;

    in property <image> viewport-image;

    in-out property <length> viewport-origin-x: 0px;
    in-out property <length> viewport-origin-y: 0px;
    in-out property <length> viewport-width: 0px;
    in-out property <length> viewport-height: 0px;

    in-out property <float> light-dir-x: 0.45;
    in-out property <float> light-dir-y: 0.7;
    in-out property <float> light-dir-z: 0.55;
    in-out property <float> light-color-r: 1.0;
    in-out property <float> light-color-g: 1.0;
    in-out property <float> light-color-b: 1.0;
    in-out property <float> ambient-r: 0.15;
    in-out property <float> ambient-g: 0.15;
    in-out property <float> ambient-b: 0.15;
    in-out property <float> diffuse-r: 1.0;
    in-out property <float> diffuse-g: 1.0;
    in-out property <float> diffuse-b: 1.0;
    in-out property <float> specular-r: 0.4;
    in-out property <float> specular-g: 0.4;
    in-out property <float> specular-b: 0.4;
    in-out property <float> shininess: 32.0;
    in-out property <bool> shading-unlit: false;

    in-out property <bool> ssao-enabled: true;
    in-out property <float> ssao-radius: 0.45;
    in-out property <float> ssao-bias: 0.025;
    in-out property <float> ssao-strength: 0.85;

    callback sync-shading-from-asset();

    in-out property <[HierarchyTreeRow]> hierarchy-tree-rows: [];
    in property <int> hierarchy-selected-entity-id: 0;

    in-out property <length> hierarchy-origin-x: 0px;
    in-out property <length> hierarchy-origin-y: 0px;
    in-out property <length> hierarchy-width: 0px;
    in-out property <length> hierarchy-height: 0px;
    in-out property <length> hierarchy-tree-origin-y: 0px;

    callback hierarchy-entity-selected(int);
    callback hierarchy-entity-toggle(int);

    in-out property <[BrowserTreeRow]> browser-tree-rows: [];
    in-out property <[BrowserGridRow]> browser-grid-rows: [];
    in-out property <[BrowserPathSegment]> browser-path-segments: [];
    in property <bool> browser-drag-active: false;
    in property <string> browser-drag-source-path: "";
    in property <string> browser-drop-highlight-path: "";
    in property <bool> browser-viewport-drop-active: false;
    in property <string> browser-status-text: "0 items";
    in property <string> browser-selected-folder-path: "";

    in-out property <length> browser-origin-x: 0px;
    in-out property <length> browser-origin-y: 0px;
    in-out property <length> browser-width: 0px;
    in-out property <length> browser-height: 0px;
    in-out property <length> browser-tree-origin-y: 0px;
    in-out property <length> browser-tree-panel-height: 0px;
    in-out property <length> browser-tree-panel-width: 150px;
    in-out property <length> browser-thumb-size: 64px;

    callback browser-folder-selected(string);
    callback browser-folder-toggle(string);
    callback browser-refresh-requested();
    callback browser-import-requested();
    callback browser-item-press(string, float, float);
    callback browser-item-move(string, float, float);
    callback browser-item-release(string, float, float);
    callback browser-search-changed(string);
    callback browser-path-segment-clicked(string);

    in property <string> inspector-entity-name: "";
    in property <bool> inspector-has-selection: false;
    in-out property <float> inspector-pos-x: 0.0;
    in-out property <float> inspector-pos-y: 0.0;
    in-out property <float> inspector-pos-z: 0.0;
    in-out property <float> inspector-rot-x: 0.0;
    in-out property <float> inspector-rot-y: 0.0;
    in-out property <float> inspector-rot-z: 0.0;
    in-out property <float> inspector-scale-x: 1.0;
    in-out property <float> inspector-scale-y: 1.0;
    in-out property <float> inspector-scale-z: 1.0;
    in-out property <float> inspector-quat-x: 0.0;
    in-out property <float> inspector-quat-y: 0.0;
    in-out property <float> inspector-quat-z: 0.0;
    in-out property <float> inspector-quat-w: 1.0;
    in property <bool> inspector-pos-x-mixed: false;
    in property <bool> inspector-pos-y-mixed: false;
    in property <bool> inspector-pos-z-mixed: false;
    in property <bool> inspector-rot-x-mixed: false;
    in property <bool> inspector-rot-y-mixed: false;
    in property <bool> inspector-rot-z-mixed: false;
    in property <bool> inspector-scale-x-mixed: false;
    in property <bool> inspector-scale-y-mixed: false;
    in property <bool> inspector-scale-z-mixed: false;
    in-out property <bool> inspector-transform-expanded: true;
    in-out property <bool> inspector-rotation-edit-mode-euler: true;
    in-out property <bool> inspector-scale-link-enabled: true;
    in property <bool> inspector-multi-edit-visible: false;
    in-out property <bool> inspector-multi-edit-absolute: true;

    callback inspector-transform-edited();
    callback inspector-field-text-committed(int, string);
    callback inspector-field-focus-changed(int, bool);
    callback inspector-rotation-mode-changed(bool);
    callback inspector-scale-link-toggled(bool);
    callback inspector-multi-edit-mode-changed(bool);
    callback save-scene-requested();
    callback edit-undo-requested();
    callback edit-redo-requested();
    in property <bool> edit-can-undo: false;
    in property <bool> edit-can-redo: false;

    in-out property <bool> viewport-is-perspective: true;
    in property <bool> viewport-image-ready: false;
    callback viewport-projection-toggled();

    in-out property <int> transform-gizmo-mode: 0;
    in-out property <bool> transform-gizmo-space-global: true;
    callback transform-mode-selected(int);
    callback gizmo-space-toggled();

    in-out property <bool> import-mesh-dialog-visible: false;
    in-out property <bool> import-mesh-materials: true;
    in-out property <bool> import-mesh-animations: true;
    in-out property <float> import-mesh-scale: 1.0;
    callback import-mesh-confirmed();
    callback import-mesh-cancelled();

    in-out property <bool> piercing-menu-visible: false;
    in-out property <length> piercing-menu-anchor-x: 0px;
    in-out property <length> piercing-menu-anchor-y: 0px;
    in-out property <[PiercingMenuRow]> piercing-menu-rows: [];
    callback piercing-entity-selected(int);
    callback piercing-menu-dismissed();

    in property <bool> docking-visible: true;
    in property <[DockTile]> docking-tiles: [];
    in property <[DockTab]> docking-tabs: [];
    in property <[DockSplitterHandle]> docking-splitters: [];
    in property <[DockGuide]> docking-guides: [];
    in property <[DockHostGuide]> docking-host-guides: [];
    in property <[DockFloating]> docking-floatings: [];
    in property <DockPreview> docking-preview;
    in property <DockPreview> docking-host-dock-preview;
    in property <DockAutoHideDropPreview> docking-auto-hide-drop-preview;
    in property <bool> docking-cross-guides-visible: false;
    in property <DockDragPreview> docking-drag-preview;
    in property <bool> docking-drag-active: false;

    out property <length> docking-width: docking_host.width;
    out property <length> docking-height: docking_host.height;
    out property <length> docking-origin-x: docking_host.absolute-position.x;
    out property <length> docking-origin-y: docking_host.absolute-position.y;

    callback docking-tab-pressed(int, length, length);
    callback docking-tab-moved(length, length);
    callback docking-tab-released(length, length);
    callback docking-tab-activated(int);
    callback docking-widget-closed(int);
    callback docking-splitter-pressed(int, length, length);
    callback docking-splitter-moved(int, length, length);
    callback docking-splitter-released();
    callback docking-floating-move-pressed(int, length, length);
    callback docking-floating-resize-pressed(int, length, length);
    callback docking-floating-moved(length, length);
    callback docking-floating-released();
    callback docking-floating-window-close(int);

    in property <[DockAutoHideTab]> docking-auto-hide-tabs: [];
    in property <[DockAutoHideOverlay]> docking-auto-hide-overlays: [];
    callback docking-auto-hide-tab-pressed(int);
    callback docking-auto-hide-tab-unpin(int);
    callback docking-tab-pin-pressed(int);
    callback docking-auto-hide-overlay-minimize(int);
    callback docking-auto-hide-overlay-close(int);
    callback docking-auto-hide-overlay-resize-pressed(int, length, length);
    callback docking-auto-hide-overlay-resize-moved(int, length, length);
    callback docking-auto-hide-overlay-resize-released();

    function reset-shading-defaults() {
        root.light-dir-x = 0.45;
        root.light-dir-y = 0.7;
        root.light-dir-z = 0.55;
        root.light-color-r = 1.0;
        root.light-color-g = 1.0;
        root.light-color-b = 1.0;
        root.ambient-r = 0.15;
        root.ambient-g = 0.15;
        root.ambient-b = 0.15;
        root.diffuse-r = 1.0;
        root.diffuse-g = 1.0;
        root.diffuse-b = 1.0;
        root.specular-r = 0.04;
        root.specular-g = 0.04;
        root.specular-b = 0.04;
        root.shininess = 169.0;
        root.shading-unlit = false;
        root.ssao-enabled = true;
        root.ssao-radius = 0.45;
        root.ssao-bias = 0.025;
        root.ssao-strength = 0.85;
    }

    root-layer := Rectangle {
        vertical-stretch: 1;

        VerticalLayout {
            width: 100%;
            height: 100%;

            Rectangle {
                background: #1f1f1f;
                border-color: #2a2a2a;
                border-width: 1px;
                height: 44px;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "Blunder Editor";
                        color: #f5f5f5;
                        font-size: 16px;
                        vertical-alignment: center;
                    }

                    Rectangle { width: 16px; }

                    Button {
                        text: "Save";
                        clicked => { root.save-scene-requested(); }
                    }
                    Button {
                        text: "Undo";
                        enabled: root.edit-can-undo;
                        clicked => { root.edit-undo-requested(); }
                    }
                    Button {
                        text: "Redo";
                        enabled: root.edit-can-redo;
                        clicked => { root.edit-redo-requested(); }
                    }
                    Button { text: "View"; }
                    Button { text: "Play"; }
                }
            }

            docking_host := Rectangle {
                vertical-stretch: 1;
                background: #161616;

                TouchArea {
                    width: 100%;
                    height: 100%;
                }

                for tile in root.docking-tiles: Rectangle {
                    x: tile.tab-x;
                    y: tile.tab-y;
                    width: tile.tab-width;
                    height: tile.tab-height;
                    background: #2d2d2d;
                }

                for tile in root.docking-tiles: Rectangle {
                    x: tile.content-x;
                    y: tile.content-y;
                    width: tile.content-width;
                    height: tile.content-height;
                    background: #2d2d2d;
                    border-color: #2a2a2a;
                    border-width: 1px;
                    clip: true;

                    if tile.active-panel-kind == 1: Rectangle {
                        width: 100%;
                        height: 100%;
                        // Blender ThemeSpaceView3D default (~0.22).
                        background: #383838;

                        Image {
                            width: 100%;
                            height: 100%;
                            source: root.viewport-image;
                            image-fit: fill;
                            visible: root.viewport-image-ready;
                        }

                        TransformToolbar {
                            x: 8px;
                            y: 8px;
                            transform-mode: root.transform-gizmo-mode;
                            gizmo-space-global: root.transform-gizmo-space-global;
                            transform-mode-selected(mode) => {
                                root.transform-mode-selected(mode);
                            }
                            gizmo-space-toggled => {
                                root.gizmo-space-toggled();
                            }
                        }
                    }

                    if tile.active-panel-kind == 2: HierarchyPanel {
                        width: 100%;
                        height: 100%;
                        tree-rows <=> root.hierarchy-tree-rows;
                        selected-entity-id: root.hierarchy-selected-entity-id;
                        tree-origin-y <=> root.hierarchy-tree-origin-y;
                        entity-selected(id) => { root.hierarchy-entity-selected(id); }
                        entity-toggle(id) => { root.hierarchy-entity-toggle(id); }
                    }

                    if tile.active-panel-kind == 4: ContentBrowser {
                        width: 100%;
                        height: 100%;
                        layout-drag-active: root.docking-drag-active;
                        tree-rows <=> root.browser-tree-rows;
                        grid-rows <=> root.browser-grid-rows;
                        path-segments <=> root.browser-path-segments;
                        drag-active: root.browser-drag-active;
                        drag-source-path: root.browser-drag-source-path;
                        drop-highlight-path: root.browser-drop-highlight-path;
                        viewport-drop-active: root.browser-viewport-drop-active;
                        status-text: root.browser-status-text;
                        selected-folder-path: root.browser-selected-folder-path;
                        tree-origin-y <=> root.browser-tree-origin-y;
                        tree-panel-height <=> root.browser-tree-panel-height;
                        tree-pane-width <=> root.browser-tree-panel-width;
                        thumb-size <=> root.browser-thumb-size;
                        folder-selected(path) => { root.browser-folder-selected(path); }
                        folder-toggle(path) => { root.browser-folder-toggle(path); }
                        refresh-requested => { root.browser-refresh-requested(); }
                        import-requested => { root.browser-import-requested(); }
                        item-press(path, x, y) => { root.browser-item-press(path, x, y); }
                        item-move(path, x, y) => { root.browser-item-move(path, x, y); }
                        item-release(path, x, y) => { root.browser-item-release(path, x, y); }
                        search-changed(text) => { root.browser-search-changed(text); }
                        path-segment-clicked(path) => { root.browser-path-segment-clicked(path); }
                    }

                    if tile.active-panel-kind == 3: InspectorPanel {
                        width: 100%;
                        height: 100%;
                        has-selection: root.inspector-has-selection;
                        entity-name: root.inspector-entity-name;
                        pos-x <=> root.inspector-pos-x;
                        pos-y <=> root.inspector-pos-y;
                        pos-z <=> root.inspector-pos-z;
                        rot-x <=> root.inspector-rot-x;
                        rot-y <=> root.inspector-rot-y;
                        rot-z <=> root.inspector-rot-z;
                        scale-x <=> root.inspector-scale-x;
                        scale-y <=> root.inspector-scale-y;
                        scale-z <=> root.inspector-scale-z;
                        quat-x <=> root.inspector-quat-x;
                        quat-y <=> root.inspector-quat-y;
                        quat-z <=> root.inspector-quat-z;
                        quat-w <=> root.inspector-quat-w;
                        pos-x-mixed: root.inspector-pos-x-mixed;
                        pos-y-mixed: root.inspector-pos-y-mixed;
                        pos-z-mixed: root.inspector-pos-z-mixed;
                        rot-x-mixed: root.inspector-rot-x-mixed;
                        rot-y-mixed: root.inspector-rot-y-mixed;
                        rot-z-mixed: root.inspector-rot-z-mixed;
                        scale-x-mixed: root.inspector-scale-x-mixed;
                        scale-y-mixed: root.inspector-scale-y-mixed;
                        scale-z-mixed: root.inspector-scale-z-mixed;
                        transform-expanded <=> root.inspector-transform-expanded;
                        rotation-edit-mode-euler <=> root.inspector-rotation-edit-mode-euler;
                        scale-link-enabled <=> root.inspector-scale-link-enabled;
                        multi-edit-visible: root.inspector-multi-edit-visible;
                        multi-edit-absolute <=> root.inspector-multi-edit-absolute;
                        light-dir-x <=> root.light-dir-x;
                        light-dir-y <=> root.light-dir-y;
                        light-dir-z <=> root.light-dir-z;
                        light-color-r <=> root.light-color-r;
                        light-color-g <=> root.light-color-g;
                        light-color-b <=> root.light-color-b;
                        ambient-r <=> root.ambient-r;
                        ambient-g <=> root.ambient-g;
                        ambient-b <=> root.ambient-b;
                        diffuse-r <=> root.diffuse-r;
                        diffuse-g <=> root.diffuse-g;
                        diffuse-b <=> root.diffuse-b;
                        specular-r <=> root.specular-r;
                        specular-g <=> root.specular-g;
                        specular-b <=> root.specular-b;
                        shininess <=> root.shininess;
                        shading-unlit <=> root.shading-unlit;
                        ssao-enabled <=> root.ssao-enabled;
                        ssao-radius <=> root.ssao-radius;
                        ssao-bias <=> root.ssao-bias;
                        ssao-strength <=> root.ssao-strength;
                        layout-drag-active: root.docking-drag-active;
                        transform-edited => { root.inspector-transform-edited(); }
                        field-text-committed(id, text) => { root.inspector-field-text-committed(id, text); }
                        field-focus-changed(id, focused) => { root.inspector-field-focus-changed(id, focused); }
                        rotation-mode-changed(euler) => { root.inspector-rotation-mode-changed(euler); }
                        scale-link-toggled(linked) => { root.inspector-scale-link-toggled(linked); }
                        multi-edit-mode-changed(absolute) => { root.inspector-multi-edit-mode-changed(absolute); }
                        sync-requested => { root.sync-shading-from-asset(); }
                        reset-requested => { root.reset-shading-defaults(); }
                    }

                    if tile.active-panel-kind == 0: Text {
                        x: 10px;
                        y: 8px;
                        text: "Panel";
                        color: #c8c8c8;
                        font-size: 13px;
                    }
                }

                for ff in root.docking-floatings: Rectangle {
                    x: ff.x;
                    y: ff.y;
                    width: ff.width;
                    height: ff.height;
                    background: transparent;
                    border-color: #4a4a4a;
                    border-width: 1px;

                    float-chrome := DockChromeBar {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: DockChromeMetrics.bar-height;
                        embedded: true;
                        chrome-bar-only: true;
                        show-chrome-move: true;
                        show-window-close: true;
                        chrome-move-pressed(px, py) => {
                            root.docking-floating-move-pressed(ff.node-id,
                                float-chrome.absolute-position.x - docking_host.absolute-position.x + px,
                                float-chrome.absolute-position.y - docking_host.absolute-position.y + py);
                        }
                        chrome-move-moved(px, py) => {
                            root.docking-floating-moved(
                                float-chrome.absolute-position.x - docking_host.absolute-position.x + px,
                                float-chrome.absolute-position.y - docking_host.absolute-position.y + py);
                        }
                        chrome-move-released() => { root.docking-floating-released(); }
                        window-close-pressed() => { root.docking-floating-window-close(ff.node-id); }
                    }

                    grip := Rectangle {
                        x: parent.width - ff.grip-size;
                        y: parent.height - ff.grip-size;
                        width: ff.grip-size;
                        height: ff.grip-size;
                        background: grip-drag.has-hover ? #3a6ea5 : #3a3a3a;

                        grip-drag := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: MouseCursor.nwse-resize;
                            moved => {
                                root.docking-floating-moved(
                                    self.absolute-position.x - docking_host.absolute-position.x + self.mouse-x,
                                    self.absolute-position.y - docking_host.absolute-position.y + self.mouse-y);
                            }
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.left
                                    && event.kind == PointerEventKind.down) {
                                    root.docking-floating-resize-pressed(ff.node-id,
                                        self.absolute-position.x - docking_host.absolute-position.x + self.mouse-x,
                                        self.absolute-position.y - docking_host.absolute-position.y + self.mouse-y);
                                }
                                if (event.button == PointerEventButton.left
                                    && event.kind == PointerEventKind.up) {
                                    root.docking-floating-released();
                                }
                            }
                        }
                    }
                }

                DockFloatingDragPreviewLayer {
                    width: 100%;
                    height: 100%;
                    preview: root.docking-drag-preview;
                }

                DockChromeBar {
                    width: 100%;
                    height: 100%;
                    tabs: root.docking-tabs;
                    tab-pressed(id, px, py) => { root.docking-tab-pressed(id, px, py); }
                    tab-moved(px, py) => { root.docking-tab-moved(px, py); }
                    tab-released(px, py) => { root.docking-tab-released(px, py); }
                    tab-activated(id) => { root.docking-tab-activated(id); }
                    widget-closed(id) => { root.docking-widget-closed(id); }
                    tab-pin-pressed(id) => { root.docking-tab-pin-pressed(id); }
                }

                DockSplittersLayer {
                    width: 100%;
                    height: 100%;
                    splitters: root.docking-splitters;
                    splitter-pressed(id, px, py) => { root.docking-splitter-pressed(id, px, py); }
                    splitter-moved(id, px, py) => { root.docking-splitter-moved(id, px, py); }
                    splitter-released() => { root.docking-splitter-released(); }
                }

                DockHostGuidesLayer {
                    width: 100%;
                    height: 100%;
                    guides: root.docking-host-guides;
                    preview: root.docking-host-dock-preview;
                }

                DockGuidesLayer {
                    width: 100%;
                    height: 100%;
                    guides: root.docking-guides;
                    preview: root.docking-preview;
                    drag-active: root.docking-drag-active;
                    show-guides: root.docking-cross-guides-visible;
                }

                DockAutoHideDropPreviewLayer {
                    width: 100%;
                    height: 100%;
                    preview: root.docking-auto-hide-drop-preview;
                }

                DockAutoHideTabsLayer {
                    width: 100%;
                    height: 100%;
                    tabs: root.docking-auto-hide-tabs;
                    tab-pressed(id) => { root.docking-auto-hide-tab-pressed(id); }
                    tab-unpin-pressed(id) => { root.docking-auto-hide-tab-unpin(id); }
                }

                // Dock-local coords; only present while an overlay is expanded.
                auto_hide_overlays := DockAutoHideOverlaysLayer {
                    width: 100%;
                    height: 100%;
                    visible: root.docking-auto-hide-overlays.length > 0;
                    overlays: root.docking-auto-hide-overlays;
                    overlay-minimize-pressed(id) => { root.docking-auto-hide-overlay-minimize(id); }
                    overlay-close-pressed(id) => { root.docking-auto-hide-overlay-close(id); }
                    overlay-resize-pressed(id, px, py) => {
                        root.docking-auto-hide-overlay-resize-pressed(id, px, py);
                    }
                    overlay-resize-moved(id, px, py) => {
                        root.docking-auto-hide-overlay-resize-moved(id, px, py);
                    }
                    overlay-resize-released() => { root.docking-auto-hide-overlay-resize-released(); }
                }

                for overlay in root.docking-auto-hide-overlays: Rectangle {
                    x: overlay.content-x;
                    y: overlay.content-y;
                    width: overlay.content-width;
                    height: overlay.content-height;
                    clip: true;
                    background: transparent;

                    if overlay.panel-kind == 2: HierarchyPanel {
                        width: 100%;
                        height: 100%;
                        tree-rows <=> root.hierarchy-tree-rows;
                        selected-entity-id: root.hierarchy-selected-entity-id;
                        tree-origin-y <=> root.hierarchy-tree-origin-y;
                        entity-selected(id) => { root.hierarchy-entity-selected(id); }
                        entity-toggle(id) => { root.hierarchy-entity-toggle(id); }
                    }

                    if overlay.panel-kind == 4: ContentBrowser {
                        width: 100%;
                        height: 100%;
                        layout-drag-active: root.docking-drag-active;
                        tree-rows <=> root.browser-tree-rows;
                        grid-rows <=> root.browser-grid-rows;
                        path-segments <=> root.browser-path-segments;
                        drag-active: root.browser-drag-active;
                        drag-source-path: root.browser-drag-source-path;
                        drop-highlight-path: root.browser-drop-highlight-path;
                        viewport-drop-active: root.browser-viewport-drop-active;
                        status-text: root.browser-status-text;
                        selected-folder-path: root.browser-selected-folder-path;
                        tree-origin-y <=> root.browser-tree-origin-y;
                        tree-panel-height <=> root.browser-tree-panel-height;
                        tree-pane-width <=> root.browser-tree-panel-width;
                        thumb-size <=> root.browser-thumb-size;
                        folder-selected(path) => { root.browser-folder-selected(path); }
                        folder-toggle(path) => { root.browser-folder-toggle(path); }
                        refresh-requested => { root.browser-refresh-requested(); }
                        import-requested => { root.browser-import-requested(); }
                        item-press(path, x, y) => { root.browser-item-press(path, x, y); }
                        item-move(path, x, y) => { root.browser-item-move(path, x, y); }
                        item-release(path, x, y) => { root.browser-item-release(path, x, y); }
                        search-changed(text) => { root.browser-search-changed(text); }
                        path-segment-clicked(path) => { root.browser-path-segment-clicked(path); }
                    }

                    if overlay.panel-kind == 3: InspectorPanel {
                        width: 100%;
                        height: 100%;
                        has-selection: root.inspector-has-selection;
                        entity-name: root.inspector-entity-name;
                        pos-x <=> root.inspector-pos-x;
                        pos-y <=> root.inspector-pos-y;
                        pos-z <=> root.inspector-pos-z;
                        rot-x <=> root.inspector-rot-x;
                        rot-y <=> root.inspector-rot-y;
                        rot-z <=> root.inspector-rot-z;
                        scale-x <=> root.inspector-scale-x;
                        scale-y <=> root.inspector-scale-y;
                        scale-z <=> root.inspector-scale-z;
                        quat-x <=> root.inspector-quat-x;
                        quat-y <=> root.inspector-quat-y;
                        quat-z <=> root.inspector-quat-z;
                        quat-w <=> root.inspector-quat-w;
                        pos-x-mixed: root.inspector-pos-x-mixed;
                        pos-y-mixed: root.inspector-pos-y-mixed;
                        pos-z-mixed: root.inspector-pos-z-mixed;
                        rot-x-mixed: root.inspector-rot-x-mixed;
                        rot-y-mixed: root.inspector-rot-y-mixed;
                        rot-z-mixed: root.inspector-rot-z-mixed;
                        scale-x-mixed: root.inspector-scale-x-mixed;
                        scale-y-mixed: root.inspector-scale-y-mixed;
                        scale-z-mixed: root.inspector-scale-z-mixed;
                        transform-expanded <=> root.inspector-transform-expanded;
                        rotation-edit-mode-euler <=> root.inspector-rotation-edit-mode-euler;
                        scale-link-enabled <=> root.inspector-scale-link-enabled;
                        multi-edit-visible: root.inspector-multi-edit-visible;
                        multi-edit-absolute <=> root.inspector-multi-edit-absolute;
                        light-dir-x <=> root.light-dir-x;
                        light-dir-y <=> root.light-dir-y;
                        light-dir-z <=> root.light-dir-z;
                        light-color-r <=> root.light-color-r;
                        light-color-g <=> root.light-color-g;
                        light-color-b <=> root.light-color-b;
                        ambient-r <=> root.ambient-r;
                        ambient-g <=> root.ambient-g;
                        ambient-b <=> root.ambient-b;
                        diffuse-r <=> root.diffuse-r;
                        diffuse-g <=> root.diffuse-g;
                        diffuse-b <=> root.diffuse-b;
                        specular-r <=> root.specular-r;
                        specular-g <=> root.specular-g;
                        specular-b <=> root.specular-b;
                        shininess <=> root.shininess;
                        shading-unlit <=> root.shading-unlit;
                        ssao-enabled <=> root.ssao-enabled;
                        ssao-radius <=> root.ssao-radius;
                        ssao-bias <=> root.ssao-bias;
                        ssao-strength <=> root.ssao-strength;
                        layout-drag-active: root.docking-drag-active;
                        transform-edited => { root.inspector-transform-edited(); }
                        field-text-committed(id, text) => { root.inspector-field-text-committed(id, text); }
                        field-focus-changed(id, focused) => { root.inspector-field-focus-changed(id, focused); }
                        rotation-mode-changed(euler) => { root.inspector-rotation-mode-changed(euler); }
                        scale-link-toggled(linked) => { root.inspector-scale-link-toggled(linked); }
                        multi-edit-mode-changed(absolute) => { root.inspector-multi-edit-mode-changed(absolute); }
                        sync-requested => { root.sync-shading-from-asset(); }
                        reset-requested => { root.reset-shading-defaults(); }
                    }
                }
            }

            Rectangle {
                background: #1f1f1f;
                border-color: #2a2a2a;
                border-width: 1px;
                height: 24px;

                Text {
                    x: 10px;
                    vertical-alignment: center;
                    text: "Hierarchy — Content Browser — Inspector";
                    color: #808080;
                    font-size: 12px;
                }
            }
        }

        ViewportProjectionToggle {
            z: 2000;
            layout-drag-active: root.docking-drag-active;
            dialog-active: root.import-mesh-dialog-visible || root.piercing-menu-visible;
            viewport-origin-x: root.viewport-origin-x;
            viewport-origin-y: root.viewport-origin-y;
            viewport-width: root.viewport-width;
            viewport-height: root.viewport-height;
            is-perspective <=> root.viewport-is-perspective;
            projection-toggled => {
                root.viewport-projection-toggled();
            }
        }

        import_mesh_dialog := ImportMeshDialog {
            z: 3000;
            width: parent.width;
            height: parent.height;
            show-dialog: root.import-mesh-dialog-visible;
            import-materials <=> root.import-mesh-materials;
            import-animations <=> root.import-mesh-animations;
            import-scale <=> root.import-mesh-scale;
            confirmed => { root.import-mesh-confirmed(); }
            cancelled => { root.import-mesh-cancelled(); }
        }

        PiercingMenu {
            z: 3500;
            width: parent.width;
            height: parent.height;
            show-menu: root.piercing-menu-visible;
            anchor-x: root.piercing-menu-anchor-x;
            anchor-y: root.piercing-menu-anchor-y;
            rows: root.piercing-menu-rows;
            entity-selected(id) => { root.piercing-entity-selected(id); }
            dismissed => { root.piercing-menu-dismissed(); }
        }
    }
}
