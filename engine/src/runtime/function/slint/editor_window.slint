import { Button, CheckBox, HorizontalBox, Slider, VerticalBox } from "std-widgets.slint";
import { ContentBrowser, BrowserTreeRow, BrowserGridRow, BrowserPathSegment } from "content_browser.slint";
import { ImportMeshDialog } from "import_mesh_dialog.slint";
import { HierarchyPanel, HierarchyTreeRow } from "hierarchy.slint";
import { VerticalResizeHandle, HorizontalResizeHandle } from "resize_splitter.slint";
import { ViewportProjectionToggle } from "viewport_projection_toggle.slint";

component ShadingSlider inherits VerticalBox {
    spacing: 2px;
    in property <string> label;
    in-out property <float> value;
    in property <float> minimum: 0.0;
    in property <float> maximum: 1.0;

    min-height: 36px;

    HorizontalBox {
        spacing: 4px;
        Text {
            text: root.label;
            color: #c0c0c0;
            font-size: 11px;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }
        Text {
            text: Math.round(root.value * 100) / 100;
            color: #bde7ff;
            font-size: 11px;
            width: 44px;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }

    Slider {
        width: 100%;
        min-height: 22px;
        minimum: root.minimum;
        maximum: root.maximum;
        value <=> root.value;
    }
}

component TransformSlider inherits VerticalBox {
    spacing: 2px;
    in property <string> label;
    in-out property <float> value;
    in property <float> minimum: -100.0;
    in property <float> maximum: 100.0;
    callback edited();

    min-height: 36px;

    HorizontalBox {
        spacing: 4px;
        Text {
            text: root.label;
            color: #c0c0c0;
            font-size: 11px;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }
        Text {
            text: Math.round(root.value * 100) / 100;
            color: #bde7ff;
            font-size: 11px;
            width: 44px;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }

    Slider {
        width: 100%;
        min-height: 22px;
        minimum: root.minimum;
        maximum: root.maximum;
        value <=> root.value;
        changed => { root.edited(); }
    }
}

export component MainEditorWindow inherits Window {
    // Logical size comes only from C++ dispatch_resize_event (see SlintWindowAdapter).
    title: "Blunder Editor";
    background: #181818;

    in property <image> viewport-image;

    in-out property <length> left-dock-width: 200px;
    in-out property <length> right-dock-width: 260px;
    in-out property <length> hierarchy-pane-height: 180px;
    in-out property <length> bottom-dock-height: 160px;
    in-out property <bool> dock-layout-drag-active: false;
    callback dock-layout-drag-changed(bool);

    function notify-dock-layout-drag(active: bool) {
        root.dock-layout-drag-active = active;
        root.dock-layout-drag-changed(active);
    }

    out property <length> viewport-origin-x: viewport-rect.absolute-position.x;
    out property <length> viewport-origin-y: viewport-rect.absolute-position.y;
    out property <length> viewport-width: viewport-rect.width;
    out property <length> viewport-height: viewport-rect.height;

    in-out property <float> light-dir-x: 0.45;
    in-out property <float> light-dir-y: 0.7;
    in-out property <float> light-dir-z: 0.55;
    in-out property <float> light-color-r: 1.0;
    in-out property <float> light-color-g: 1.0;
    in-out property <float> light-color-b: 1.0;
    in-out property <float> ambient-r: 0.15;
    in-out property <float> ambient-g: 0.15;
    in-out property <float> ambient-b: 0.15;
    in-out property <float> diffuse-r: 1.0;
    in-out property <float> diffuse-g: 1.0;
    in-out property <float> diffuse-b: 1.0;
    in-out property <float> specular-r: 0.4;
    in-out property <float> specular-g: 0.4;
    in-out property <float> specular-b: 0.4;
    in-out property <float> shininess: 32.0;
    in-out property <bool> shading-unlit: false;

    in-out property <bool> ssao-enabled: true;
    in-out property <float> ssao-radius: 0.45;
    in-out property <float> ssao-bias: 0.025;
    in-out property <float> ssao-strength: 0.85;

    callback sync-shading-from-asset();

    in-out property <[HierarchyTreeRow]> hierarchy-tree-rows: [];
    in property <int> hierarchy-selected-entity-id: 0;

    out property <length> hierarchy-origin-x: hierarchy_panel.hierarchy-origin-x;
    out property <length> hierarchy-origin-y: hierarchy_panel.hierarchy-origin-y;
    out property <length> hierarchy-width: hierarchy_panel.hierarchy-width;
    out property <length> hierarchy-height: hierarchy_panel.hierarchy-height;
    out property <length> hierarchy-tree-origin-y: hierarchy_panel.tree-origin-y;

    callback hierarchy-entity-selected(int);
    callback hierarchy-entity-toggle(int);

    in-out property <[BrowserTreeRow]> browser-tree-rows: [];
    in-out property <[BrowserGridRow]> browser-grid-rows: [];
    in-out property <[BrowserPathSegment]> browser-path-segments: [];
    in property <bool> browser-drag-active: false;
    in property <string> browser-drag-source-path: "";
    in property <string> browser-drop-highlight-path: "";
    in property <bool> browser-viewport-drop-active: false;
    in property <string> browser-status-text: "0 items";
    in property <string> browser-selected-folder-path: "";

    out property <length> browser-origin-x: content_browser.browser-origin-x;
    out property <length> browser-origin-y: content_browser.browser-origin-y;
    out property <length> browser-width: content_browser.browser-width;
    out property <length> browser-height: content_browser.browser-height;
    out property <length> browser-tree-origin-y: content_browser.tree-origin-y;
    out property <length> browser-tree-panel-height: content_browser.tree-panel-height;
    in-out property <length> browser-tree-panel-width <=> content_browser.tree-pane-width;
    in-out property <length> browser-thumb-size <=> content_browser.thumb-size;

    callback browser-folder-selected(string);
    callback browser-folder-toggle(string);
    callback browser-refresh-requested();
    callback browser-import-requested();
    callback browser-item-press(string, float, float);
    callback browser-item-move(string, float, float);
    callback browser-item-release(string, float, float);
    callback browser-search-changed(string);
    callback browser-path-segment-clicked(string);

    in property <string> inspector-entity-name: "";
    in property <bool> inspector-has-selection: false;
    in-out property <float> inspector-pos-x: 0.0;
    in-out property <float> inspector-pos-y: 0.0;
    in-out property <float> inspector-pos-z: 0.0;
    in-out property <float> inspector-rot-x: 0.0;
    in-out property <float> inspector-rot-y: 0.0;
    in-out property <float> inspector-rot-z: 0.0;
    in-out property <float> inspector-scale-x: 1.0;
    in-out property <float> inspector-scale-y: 1.0;
    in-out property <float> inspector-scale-z: 1.0;

    callback inspector-transform-edited();
    callback save-scene-requested();

    in-out property <bool> viewport-is-perspective: true;
    in property <bool> viewport-image-ready: false;
    callback viewport-projection-toggled();

    in-out property <bool> import-mesh-dialog-visible: false;
    in-out property <bool> import-mesh-materials: true;
    in-out property <bool> import-mesh-animations: true;
    in-out property <float> import-mesh-scale: 1.0;
    callback import-mesh-confirmed();
    callback import-mesh-cancelled();

    function reset-shading-defaults() {
        root.light-dir-x = 0.45;
        root.light-dir-y = 0.7;
        root.light-dir-z = 0.55;
        root.light-color-r = 1.0;
        root.light-color-g = 1.0;
        root.light-color-b = 1.0;
        root.ambient-r = 0.15;
        root.ambient-g = 0.15;
        root.ambient-b = 0.15;
        root.diffuse-r = 1.0;
        root.diffuse-g = 1.0;
        root.diffuse-b = 1.0;
        root.specular-r = 0.04;
        root.specular-g = 0.04;
        root.specular-b = 0.04;
        root.shininess = 169.0;
        root.shading-unlit = false;
        root.ssao-enabled = true;
        root.ssao-radius = 0.45;
        root.ssao-bias = 0.025;
        root.ssao-strength = 0.85;
    }

    root-layer := Rectangle {
        vertical-stretch: 1;

    VerticalLayout {
        width: 100%;
        height: 100%;

        Rectangle {
            background: #1f1f1f;
            border-color: #2a2a2a;
            border-width: 1px;
            height: 44px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: start;

                Text {
                    text: "Blunder Editor";
                    color: #f5f5f5;
                    font-size: 16px;
                    vertical-alignment: center;
                }

                Rectangle { width: 16px; }

                Button {
                    text: "Save";
                    clicked => { root.save-scene-requested(); }
                }
                Button { text: "Edit"; }
                Button { text: "View"; }
                Button { text: "Play"; }
            }
        }

        main-split := VerticalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            editor-body := HorizontalLayout {
                vertical-stretch: 1;

                left-dock := VerticalLayout {
                    width: root.left-dock-width;
                    spacing: 0px;
                    vertical-stretch: 1;

                    hierarchy_panel := HierarchyPanel {
                        vertical-stretch: 1;
                        tree-rows <=> root.hierarchy-tree-rows;
                        selected-entity-id: root.hierarchy-selected-entity-id;
                        entity-selected(id) => { root.hierarchy-entity-selected(id); }
                        entity-toggle(id) => { root.hierarchy-entity-toggle(id); }
                    }
                }

            left-splitter := VerticalResizeHandle {
                pane-size: root.left-dock-width;
                min-pane: 180px;
                max-pane: Math.max(180px, editor-body.width - root.right-dock-width - 360px);
            }

            viewport-rect := Rectangle {
                background: #0a0a0a;
                border-color: #2a2a2a;
                border-width: 1px;
                horizontal-stretch: 1;
                vertical-stretch: 1;
                min-width: 120px;

                Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.viewport-image;
                    image-fit: fill;
                    visible: root.viewport-image-ready;
                }
            }

            right-splitter := VerticalResizeHandle {
                pane-size: root.right-dock-width;
                min-pane: 200px;
                max-pane: Math.max(200px, editor-body.width - root.left-dock-width - 360px);

                trailing-pane: true;
            }

            inspector-dock := Rectangle {
                background: #1c1c1c;
                border-color: #2a2a2a;
                border-width: 1px;
                width: root.right-dock-width;
                vertical-stretch: 1;
                clip: true;
                VerticalLayout {
                    padding: 10px;
                    spacing: 8px;

                    Text {
                        text: "Inspector";
                        color: #d0d0d0;
                        font-size: 14px;
                    }
                    Rectangle { background: #2a2a2a; height: 1px; }

                    inspector-scroll := Flickable {
                        vertical-stretch: 1;
                        interactive: !root.dock-layout-drag-active;
                        viewport-width: parent.width - 20px;
                        // Large fixed scroll extent avoids remeasuring every slider row each splitter frame.
                        viewport-height: 2400px;

                        inspector-panel := VerticalBox {
                            width: parent.width;
                            spacing: 6px;
                            padding-right: 4px;

                            Text {
                                text: "Transform";
                                color: #f0f0f0;
                                font-size: 13px;
                            }

                            Text {
                                text: root.inspector-has-selection
                                    ? root.inspector-entity-name
                                    : "No selection";
                                color: #a8a8a8;
                                font-size: 12px;
                            }

                            Text { text: "Position"; color: #a8a8a8; font-size: 12px; }
                            TransformSlider {
                                label: "X";
                                minimum: -200;
                                maximum: 200;
                                value <=> root.inspector-pos-x;
                                edited => { root.inspector-transform-edited(); }
                            }
                            TransformSlider {
                                label: "Y";
                                minimum: -200;
                                maximum: 200;
                                value <=> root.inspector-pos-y;
                                edited => { root.inspector-transform-edited(); }
                            }
                            TransformSlider {
                                label: "Z";
                                minimum: -200;
                                maximum: 200;
                                value <=> root.inspector-pos-z;
                                edited => { root.inspector-transform-edited(); }
                            }

                            Text { text: "Rotation (deg)"; color: #a8a8a8; font-size: 12px; }
                            TransformSlider {
                                label: "X";
                                minimum: -180;
                                maximum: 180;
                                value <=> root.inspector-rot-x;
                                edited => { root.inspector-transform-edited(); }
                            }
                            TransformSlider {
                                label: "Y";
                                minimum: -180;
                                maximum: 180;
                                value <=> root.inspector-rot-y;
                                edited => { root.inspector-transform-edited(); }
                            }
                            TransformSlider {
                                label: "Z";
                                minimum: -180;
                                maximum: 180;
                                value <=> root.inspector-rot-z;
                                edited => { root.inspector-transform-edited(); }
                            }

                            Text { text: "Scale"; color: #a8a8a8; font-size: 12px; }
                            TransformSlider {
                                label: "X";
                                minimum: 0.01;
                                maximum: 10;
                                value <=> root.inspector-scale-x;
                                edited => { root.inspector-transform-edited(); }
                            }
                            TransformSlider {
                                label: "Y";
                                minimum: 0.01;
                                maximum: 10;
                                value <=> root.inspector-scale-y;
                                edited => { root.inspector-transform-edited(); }
                            }
                            TransformSlider {
                                label: "Z";
                                minimum: 0.01;
                                maximum: 10;
                                value <=> root.inspector-scale-z;
                                edited => { root.inspector-transform-edited(); }
                            }

                            Rectangle { background: #2a2a2a; height: 1px; }

                            Text {
                                text: "Blinn-Phong Shading";
                                color: #f0f0f0;
                                font-size: 13px;
                            }

                            HorizontalBox {
                                spacing: 6px;
                                Button {
                                    text: "Sync Asset";
                                    clicked => { root.sync-shading-from-asset(); }
                                }
                                Button {
                                    text: "Reset";
                                    clicked => { root.reset-shading-defaults(); }
                                }
                            }

                            CheckBox {
                                text: "Unlit (albedo only)";
                                checked: root.shading-unlit;
                                toggled => { root.shading-unlit = self.checked; }
                            }

                            Text { text: "Light direction"; color: #a8a8a8; font-size: 12px; }
                            ShadingSlider { label: "Dir X"; minimum: -1; maximum: 1; value <=> root.light-dir-x; }
                            ShadingSlider { label: "Dir Y"; minimum: -1; maximum: 1; value <=> root.light-dir-y; }
                            ShadingSlider { label: "Dir Z"; minimum: -1; maximum: 1; value <=> root.light-dir-z; }

                            Text { text: "Light color"; color: #a8a8a8; font-size: 12px; }
                            ShadingSlider { label: "R"; value <=> root.light-color-r; }
                            ShadingSlider { label: "G"; value <=> root.light-color-g; }
                            ShadingSlider { label: "B"; value <=> root.light-color-b; }

                            Text { text: "Ambient (ka)"; color: #a8a8a8; font-size: 12px; }
                            ShadingSlider { label: "R"; value <=> root.ambient-r; }
                            ShadingSlider { label: "G"; value <=> root.ambient-g; }
                            ShadingSlider { label: "B"; value <=> root.ambient-b; }

                            Text { text: "Diffuse (kd)"; color: #a8a8a8; font-size: 12px; }
                            ShadingSlider { label: "R"; value <=> root.diffuse-r; }
                            ShadingSlider { label: "G"; value <=> root.diffuse-g; }
                            ShadingSlider { label: "B"; value <=> root.diffuse-b; }

                            Text { text: "Specular (ks)"; color: #a8a8a8; font-size: 12px; }
                            ShadingSlider { label: "R"; value <=> root.specular-r; }
                            ShadingSlider { label: "G"; value <=> root.specular-g; }
                            ShadingSlider { label: "B"; value <=> root.specular-b; }

                            ShadingSlider {
                                label: "Shininess";
                                minimum: 8;
                                maximum: 256;
                                value <=> root.shininess;
                            }

                            Text { text: "SSAO"; color: #a8a8a8; font-size: 12px; }
                            CheckBox {
                                text: "Enabled";
                                checked: root.ssao-enabled;
                                toggled => { root.ssao-enabled = self.checked; }
                            }
                            ShadingSlider {
                                label: "Radius";
                                minimum: 0.05;
                                maximum: 1.0;
                                value <=> root.ssao-radius;
                            }
                            ShadingSlider {
                                label: "Bias";
                                minimum: 0.0;
                                maximum: 0.1;
                                value <=> root.ssao-bias;
                            }
                            ShadingSlider {
                                label: "Strength";
                                minimum: 0.0;
                                maximum: 1.0;
                                value <=> root.ssao-strength;
                            }
                        }
                    }
                }
            }

            } // end editor-body

            // Bottom splitter between editor body and content browser
            bottom-splitter := HorizontalResizeHandle {
                pane-size: root.bottom-dock-height;
                min-pane: 120px;
                // Keep at least ~400px for the central viewport + side docks.
                max-pane: Math.max(120px, main-split.height - 400px);
                trailing-pane: true;
            }

            // Bottom dock: Content Browser (full width)
            bottom-dock := Rectangle {
                height: root.bottom-dock-height;
                horizontal-stretch: 1;

                content_browser := ContentBrowser {
                    width: parent.width;
                    height: parent.height;
                    layout-drag-active: root.dock-layout-drag-active;
                    tree-rows <=> root.browser-tree-rows;
                    grid-rows <=> root.browser-grid-rows;
                    path-segments <=> root.browser-path-segments;
                    drag-active: root.browser-drag-active;
                    drag-source-path: root.browser-drag-source-path;
                    drop-highlight-path: root.browser-drop-highlight-path;
                    viewport-drop-active: root.browser-viewport-drop-active;
                    status-text: root.browser-status-text;
                    selected-folder-path: root.browser-selected-folder-path;
                    folder-selected(path) => { root.browser-folder-selected(path); }
                    folder-toggle(path) => { root.browser-folder-toggle(path); }
                    refresh-requested => { root.browser-refresh-requested(); }
                    import-requested => { root.browser-import-requested(); }
                    item-press(path, x, y) => { root.browser-item-press(path, x, y); }
                    item-move(path, x, y) => { root.browser-item-move(path, x, y); }
                    item-release(path, x, y) => { root.browser-item-release(path, x, y); }
                    search-changed(text) => { root.browser-search-changed(text); }
                    path-segment-clicked(path) => { root.browser-path-segment-clicked(path); }
                }
            }

        } // end main-split

        Rectangle {
            background: #1f1f1f;
            border-color: #2a2a2a;
            border-width: 1px;
            height: 24px;

            Text {
                x: 10px;
                vertical-alignment: center;
                text: "Hierarchy — Content Browser — Inspector";
                color: #808080;
                font-size: 12px;
            }
        }
    }

    // Window-level overlay so the viewport Image does not steal pointer hits.
    ViewportProjectionToggle {
        z: 2000;
        layout-drag-active: root.dock-layout-drag-active;
        dialog-active: root.import-mesh-dialog-visible;
        viewport-origin-x: root.viewport-origin-x;
        viewport-origin-y: root.viewport-origin-y;
        viewport-width: root.viewport-width;
        viewport-height: root.viewport-height;
        is-perspective <=> root.viewport-is-perspective;
        projection-toggled => {
            root.viewport-projection-toggled();
        }
    }

    import_mesh_dialog := ImportMeshDialog {
        z: 3000;
        width: parent.width;
        height: parent.height;
        show-dialog: root.import-mesh-dialog-visible;
        import-materials <=> root.import-mesh-materials;
        import-animations <=> root.import-mesh-animations;
        import-scale <=> root.import-mesh-scale;
        confirmed => { root.import-mesh-confirmed(); }
        cancelled => { root.import-mesh-cancelled(); }
    }
    }
}
